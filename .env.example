# --- Server ---------------------------------------------------------------
# Supabase project → Settings → Database → Connection string (use the
# "Transaction" pooler URI on port 6543 for serverless-friendly connections).
# If your password has special characters (# % / : @ ? &), percent-encode
# them — e.g. via `node -e "console.log(encodeURIComponent('your-password'))"`.
DATABASE_URL=postgresql://postgres:[password]@[project-ref].pooler.supabase.com:6543/postgres

# Supabase project → Settings → API. SUPABASE_URL is the bare project URL —
# do not append /rest/v1/ or any other path.
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Bucket for food-photo uploads (create it in Supabase Storage; private is fine).
SUPABASE_STORAGE_BUCKET=food-photos

# The Supabase Auth user id (uuid) of the app owner — grants admin role +
# unlimited AI calls. Find it in Supabase → Authentication → Users after
# your first login.
OWNER_OPEN_ID=

ANTHROPIC_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SENTRY_DSN=
EDAMAM_APP_ID=
EDAMAM_APP_KEY=

# Railway sets this automatically — do not set manually in production.
PORT=3000
NODE_ENV=development

# --- Client (must be prefixed VITE_ to be exposed to the browser) ---------
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=
